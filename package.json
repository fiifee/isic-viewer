{
  "name": "isic-viewer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "homepage": "https://fiifee.github.io/isic-viewer",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "build:backend": "tsc -p server/tsconfig.json",
    "start": "node dist-server/index.js",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "cap:sync": "npm run build && npx cap sync",
    "cap:open:ios": "npm run build && npx cap sync && npx cap open ios",
    "cap:open:android": "npm run build && npx cap sync && npx cap open android",
    "cap:update": "npx cap update"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/status-bar": "^8.0.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "gh-pages": "^6.3.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  }
}
